{
    "name": "mapbender/mapbender",
    "description": "Mapbender library",
    "keywords": ["mapbender", "module"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-dom": "*",
        "ext-gd": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-zip": "*",

        "symfony/asset": "^7.4",
        "symfony/config": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dotenv": "^7.4",
        "symfony/debug-bundle": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/doctrine-bridge": "^7.4",
        "symfony/error-handler": "^7.4",
        "symfony/event-dispatcher": "^7.4",
        "symfony/filesystem": "^7.4",
        "symfony/finder": "^7.4",
        "symfony/flex": "^2.3",
        "symfony/form": "^7.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/http-client": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/http-kernel": "^7.4",
        "symfony/intl": "^7.4",
        "symfony/mailer": "^7.4",
        "symfony/mime": "^7.4",
        "symfony/monolog-bundle": "^3",
        "symfony/options-resolver": "^7.4",
        "symfony/routing": "^7.4",
        "symfony/runtime": "^7.4",
        "symfony/security-acl": "~3.0",
        "symfony/security-bundle": "^7.4",
        "symfony/security-core": "^7.4",
        "symfony/security-csrf": "^7.4",
        "symfony/security-http": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/translation": "^7.4",
        "symfony/twig-bridge": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/validator": "^7.4",
        "symfony/web-link": "^7.4",
        "symfony/web-profiler-bundle": "^7.4",
        "symfony/yaml": "^7.4",

        "twig/twig": "^3.6",
        "doctrine/orm": "^3.6",
        "doctrine/dbal": "^4.4",
        "doctrine/persistence": "^4.2",
        "doctrine/doctrine-bundle": "^2",
        "shuchkin/simplexlsxgen": "^1.3",

        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2",

        "assetic/framework": "^3.1",
        "scssphp/scssphp": "^1.12",

        "mapbender/mapbender-icons": "^1.3",

        "wheregroup/codemirror": "5.x",


        "npm-asset/jquery": "^4.0",
        "jquery/jquery-ui": "^1.14.1",
        "datatables.net/datatables.net-bs5": "^2.3",
        "twbs/bootstrap": "^5.0",

        "mapbender/openlayers6-es5": "^10"
    },
    "provide": {
        "mapbender/fom": "3.3",
        "mapbender/owsproxy": "3.3.99"
    },
    "replace": {
        "mapbender/owsproxy": "3.3.*",
        "mapbender/fom": "*",
        "components/jquery": "*"
    },
    "autoload": {
        "psr-4": {
            "Mapbender\\": "src/Mapbender",
            "OwsProxy3\\": "src/OwsProxy3",
            "FOM\\": "src/FOM"
        }
    },
    "conflict": {
        "mapbender/digitizer": "<2.0.0",
        "symfony/symfony": "*"
    },
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "jquery/jquery-ui",
                "version": "1.14.1",
                "source": {
                    "url": "https://github.com/jquery/jquery-ui",
                    "type": "git",
                    "reference": "1.14.1"
                }
            }
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
