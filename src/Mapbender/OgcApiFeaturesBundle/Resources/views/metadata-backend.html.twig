{% extends "@MapbenderManager/Repository/source/view.html.twig" %}
{%- import '@MapbenderManager/macros/tabs.html.twig' as tab_macros -%}

{% block tab_headers %}
    {{ parent() }}
    {{- tab_macros.tab_header('Styles', 'mb.ogcapifeatures.admin.style.title') -}}
{% endblock tab_headers %}

{% block tab_containers %}
    {{ parent() }}
    <div{{ tab_macros.tab_content_attributes('Styles', 'serviceContainer') }}>
        {% block styles_content %}
            {% if styles is defined and styles|length > 0 %}
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:50px">{{ 'mb.ogcapifeatures.admin.style.manager.th_id' | trans }}</th>
                            <th>{{ 'mb.ogcapifeatures.admin.style.manager.th_name' | trans }}</th>
                            <th>{{ 'mb.ogcapifeatures.admin.source_tab.collection' | trans }}</th>
                            <th style="width:80px">{{ 'mb.ogcapifeatures.admin.source_tab.layers' | trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for style in styles %}
                            <tr>
                                <td>{{ style.id }}</td>
                                <td>
                                    <a href="{{ path('mapbender_manager_style_view', {id: style.id}) }}">
                                        {{ style.name }}
                                    </a>
                                </td>
                                <td>{{ style.collectionId ?? '-' }}</td>
                                <td>{{ style.layerCount }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted">{{ 'mb.ogcapifeatures.admin.source_tab.no_styles' | trans }}</p>
            {% endif %}
        {% endblock styles_content %}
    </div>
{% endblock tab_containers %}

{% block metadata_content %}
    <table>
        <tr>
            <th>{{ 'mb.ogcapifeatures.metadata.title' | trans }}:</th>
            <td>{{ source.title }}</td>
        </tr>
        <tr>
            <th>{{ 'mb.ogcapifeatures.metadata.version' | trans }}:</th>
            <td>{{ source.version }}</td>
        </tr>
        <tr>
            <th>{{ 'mb.ogcapifeatures.metadata.url' | trans }}:</th>
            <td>{{ source.jsonUrl | linkify }}</td>
        </tr>
        <tr>
            <th>{{ 'mb.ogcapifeatures.metadata.description' | trans }}:</th>
            <td>{{ source.description | linkify }}</td>
        </tr>
    </table>
{% endblock metadata_content %}

{% block details_content %}
    <table>
        <tr>
            <th>{{ 'mb.ogcapifeatures.metadata.attribution' | trans }}:</th>
            <td>{{ source.attribution|raw }}</td>
        </tr>
    </table>
{% endblock %}
{% block layers_content %}
    {% for layer in source.layers %}
        <div{%- if source.layers|length > 1 %} class="content-toggle-container closed"{%- endif -%}>
            <div class="h4 clearfix{%- if source.layers|length > 1 %} content-toggle clickable{%- endif -%}">
                {%- if source.layers|length > 1 -%}
                    <i class="pull-right fa-solid fa-caret-right me-3"></i>
                {%- endif -%}
                {{ layer.title }}
            </div>
            <div{%- if source.layers|length > 1 %} class="content-toggle-target"{%- endif -%}>
                {% set collectionUrl = source.jsonUrl ~ '/collections/' ~ layer.collectionId %}
                <table>
                    <tr>
                        <th>{{ 'mb.ogcapifeatures.metadata.title' | trans }}:</th>
                        <td>{{ layer.title }}</td>
                    </tr>
                    <tr>
                        <th>{{ 'mb.ogcapifeatures.metadata.url' | trans }}:</th>
                        <td>{{ collectionUrl|linkify }}</td>
                    </tr>
                </table>
                {% set propTitles = layer.propertyTitles %}
                {% set propKeys = layer.propertyKeys %}
                {% if propKeys|length > 0 %}
                    <h5 class="mt-2">{{ 'mb.ogcapifeatures.admin.source_tab.properties' | trans }}</h5>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>{{ 'mb.ogcapifeatures.admin.source_tab.property_key' | trans }}</th>
                                <th>{{ 'mb.ogcapifeatures.admin.source_tab.property_title' | trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for key in propKeys %}
                                <tr>
                                    <td><code>{{ key }}</code></td>
                                    <td>{{ propTitles[key]|default('-') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
        <tr>
    {% endfor %}
{% endblock layers_content %}
