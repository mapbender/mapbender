<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <parameters>
        <parameter key="mapbender.source.ogc_api.class">Mapbender\OgcApiFeaturesBundle\OgcApiFeaturesDataSource</parameter>
    </parameters>
    <services>
        <service id="mapbender.source.ogc_api" class="%mapbender.source.ogc_api.class%">
            <tag name="mapbender.datasource" />
            <argument type="service" id="mapbender.source.ogc_api.config_generator" />
            <argument type="service" id="mapbender.source.ogc_api.instance_factory" />
            <argument type="service" id="mapbender.source.ogc_api.loader" />
            <argument type="service" id="mapbender.source.ogc_api.renderer" />
        </service>
        <service id="mapbender.source.ogc_api.config_generator"
                 class="Mapbender\OgcApiFeaturesBundle\Component\OgcApiFeaturesConfigGenerator">
        </service>
        <service id="mapbender.source.ogc_api.instance_factory"
                 class="Mapbender\OgcApiFeaturesBundle\Component\OgcApiFeaturesInstanceFactory"
                 lazy="true">
            <argument type="service" id="Doctrine\ORM\EntityManagerInterface" />
        </service>
        <service id="mapbender.source.ogc_api.loader"
                 class="Mapbender\OgcApiFeaturesBundle\Component\OgcApiFeaturesLoader" lazy="true">
            <argument type="service" id="mapbender.http_transport.service" />
            <argument type="service" id="translator" />
            <argument type="service" id="Doctrine\ORM\EntityManagerInterface" />
        </service>
        <service id="mapbender.source.ogc_api.renderer"
                 class="Mapbender\OgcApiFeaturesBundle\Component\OgcApiFeaturesRenderer"
                 lazy="true">
        </service>
        <service id="mapbender.source.ogc_api.instance_type"
                 class="Mapbender\OgcApiFeaturesBundle\Form\Type\OgcApiFeaturesInstanceType">
            <tag name="form.type" />
            <argument type="service" id="translator" />
        </service>
        <service id="mapbender.source.ogc_api.instance_layer_type"
                 class="Mapbender\OgcApiFeaturesBundle\Form\Type\OgcApiFeaturesInstanceLayerType">
            <tag name="form.type" />
            <argument type="service" id="Doctrine\ORM\EntityManagerInterface" />
        </service>
    </services>
</container>
