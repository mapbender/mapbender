{% extends '@MapbenderManager/manager.html.twig' %}
{%- set title = (readonly|default(false)) ? 'View Style #' ~ style.id : (style.id ? 'Edit Style #' ~ style.id : 'New Style') -%}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/mapbendermanager/css/style-editor.css') }}">
{% endblock %}

{% block manager_content %}
    <form method="post" novalidate action="{{ style.id ? path('mapbender_manager_style_edit', {id: style.id}) : path('mapbender_manager_style_new') }}">
        {% if readonly|default(false) %}<fieldset disabled>{% endif %}
        <input type="hidden" id="sourceType" name="sourceType" value="{{ style.sourceType|default('manual') }}">
        <div class="mb-4">
            <label for="name" class="form-label fw-bold">Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control{{ nameError|default(false) ? ' is-invalid' : '' }}" id="name" name="name" value="{{ style.name }}" required placeholder="Enter style name...">
            {% if nameError|default(false) %}
                <div class="invalid-feedback">Style name is required.</div>
            {% endif %}
        </div>

        <div class="style-editor-tabs">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" id="tab-visual" data-bs-toggle="tab" data-bs-target="#pane-visual" role="tab">
                        <i class="fas fa-palette tab-icon"></i>Visual Editor
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" id="tab-json" data-bs-toggle="tab" data-bs-target="#pane-json" role="tab">
                        <i class="fas fa-code tab-icon"></i>Mapbox JSON
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" id="tab-import" data-bs-toggle="tab" data-bs-target="#pane-import" role="tab">
                        <i class="fas fa-file-import tab-icon"></i>Import
                    </a>
                </li>
            </ul>
            <div class="tab-content">
                {# ── Visual Editor Tab ── #}
                <div class="tab-pane fade show active" id="pane-visual" role="tabpanel">
                    <fieldset>
                        <legend><i class="fas fa-fill-drip me-1"></i>Fill</legend>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Color</label>
                                    <div class="input-group -js-colorpicker">
                                        <input data-prop="fillColor" class="form-control" type="text" value="{{ _visual.fillColor ?? '#ff0000' }}">
                                        <span class="input-group-text input-group-addon"><i></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold w-100">Opacity <span class="float-end badge bg-secondary value-preview"></span></label>
                                    <input data-prop="fillOpacity" class="form-range" type="range" min="0" max="1" step="any" value="{{ _visual.fillOpacity ?? 1 }}">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Point Radius</label>
                                    <input data-prop="pointRadius" type="number" min="0" max="30" step="1" class="form-control" value="{{ _visual.pointRadius ?? 5 }}">
                                </div>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend><i class="fas fa-pen me-1"></i>Stroke</legend>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Color</label>
                                    <div class="input-group -js-colorpicker">
                                        <input data-prop="strokeColor" class="form-control" type="text" value="{{ _visual.strokeColor ?? '#ffffff' }}">
                                        <span class="input-group-text input-group-addon"><i></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold w-100">Opacity <span class="float-end badge bg-secondary value-preview"></span></label>
                                    <input data-prop="strokeOpacity" class="form-range" type="range" min="0" max="1" step="any" value="{{ _visual.strokeOpacity ?? 1 }}">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Width</label>
                                    <input data-prop="strokeWidth" type="number" min="0" max="10" step="1" class="form-control" value="{{ _visual.strokeWidth ?? 1 }}">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Line Cap</label>
                                    <select data-prop="strokeLinecap" class="form-select">
                                        <option value="round"{{ _visual.strokeLinecap == 'round' ? ' selected' : '' }}>Round</option>
                                        <option value="square"{{ _visual.strokeLinecap == 'square' ? ' selected' : '' }}>Square</option>
                                        <option value="butt"{{ _visual.strokeLinecap == 'butt' ? ' selected' : '' }}>Butt</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Dash Style</label>
                                    <select data-prop="strokeDashstyle" class="form-select">
                                        <option value="solid"{{ _visual.strokeDashstyle == 'solid' ? ' selected' : '' }}>Solid</option>
                                        <option value="dot"{{ _visual.strokeDashstyle == 'dot' ? ' selected' : '' }}>Dot</option>
                                        <option value="dash"{{ _visual.strokeDashstyle == 'dash' ? ' selected' : '' }}>Dash</option>
                                        <option value="longdash"{{ _visual.strokeDashstyle == 'longdash' ? ' selected' : '' }}>Long Dash</option>
                                        <option value="dashdot"{{ _visual.strokeDashstyle == 'dashdot' ? ' selected' : '' }}>Dash Dot</option>
                                        <option value="longdashdot"{{ _visual.strokeDashstyle == 'longdashdot' ? ' selected' : '' }}>Long Dash Dot</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend><i class="fas fa-font me-1"></i>Label</legend>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Text</label>
                            <input data-prop="label" type="text" class="form-control" value="{{ _visual.label ?? '' }}" placeholder="e.g. ${name}">
                        </div>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Font Family</label>
                                    <select data-prop="fontFamily" class="form-select">
                                        {% set families = {
                                            'Arial, Helvetica, sans-serif': 'Arial',
                                            'Arial Black, Gadget, sans-serif': 'Arial Black',
                                            'Comic Sans MS, cursive, sans-serif': 'Comic Sans',
                                            'Georgia, serif': 'Georgia',
                                            'Impact, Charcoal, sans-serif': 'Impact',
                                            'Lucida Sans Unicode, Lucida Grande, sans-serif': 'Lucida',
                                            'Palatino Linotype, Book Antiqua, Palatino, serif': 'Palatino',
                                            'Tahoma, Geneva, sans-serif': 'Tahoma',
                                            'Times New Roman, Times, serif': 'Times New Roman',
                                            'Trebuchet MS, Helvetica, sans-serif': 'Trebuchet',
                                            'Verdana, Geneva, sans-serif': 'Verdana'
                                        } %}
                                        {% for val, lbl in families %}
                                            <option value="{{ val }}"{{ _visual.fontFamily == val ? ' selected' : '' }}>{{ lbl }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Size</label>
                                    <input data-prop="fontSize" type="number" min="5" max="30" class="form-control" value="{{ _visual.fontSize ?? 11 }}">
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Weight</label>
                                    <select data-prop="fontWeight" class="form-select">
                                        <option value="regular"{{ _visual.fontWeight == 'regular' ? ' selected' : '' }}>Regular</option>
                                        <option value="bold"{{ _visual.fontWeight == 'bold' ? ' selected' : '' }}>Bold</option>
                                        <option value="italic"{{ _visual.fontWeight == 'italic' ? ' selected' : '' }}>Italic</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Font Color</label>
                                    <div class="input-group -js-colorpicker">
                                        <input data-prop="fontColor" class="form-control" type="text" value="{{ _visual.fontColor ?? '#000000' }}">
                                        <span class="input-group-text input-group-addon"><i></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold w-100">Font Opacity <span class="float-end badge bg-secondary value-preview"></span></label>
                                    <input data-prop="fontOpacity" class="form-range" type="range" min="0" max="1" step="any" value="{{ _visual.fontOpacity ?? 1 }}">
                                </div>
                            </div>
                        </div>
                    </fieldset>

                    {# ── Preview ── #}
                    <fieldset>
                        <legend><i class="fas fa-eye me-1"></i>Preview</legend>
                        <div class="row text-center">
                            <div class="col-sm-4">
                                <label class="form-label fw-bold d-block">Point</label>
                                <canvas id="preview-point" data-geom="point" width="160" height="120" style="border:1px solid #dee2e6; border-radius:4px; background:#f8f9fa;"></canvas>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-bold d-block">Line</label>
                                <canvas id="preview-line" data-geom="line" width="160" height="120" style="border:1px solid #dee2e6; border-radius:4px; background:#f8f9fa;"></canvas>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-bold d-block">Polygon</label>
                                <canvas id="preview-polygon" data-geom="polygon" width="160" height="120" style="border:1px solid #dee2e6; border-radius:4px; background:#f8f9fa;"></canvas>
                            </div>
                        </div>
                    </fieldset>
                </div>

                {# ── Mapbox JSON Tab ── #}
                <div class="tab-pane fade" id="pane-json" role="tabpanel">
                    <div class="mb-3">
                        <label for="style" class="form-label fw-bold">Mapbox Style (JSON)</label>
                        <textarea class="form-control" id="style" name="style" rows="24"
                                  data-collection-id="{{ style.collectionId|default('') }}">{{ style.style }}</textarea>
                    </div>
                </div>

                {# ── Import Tab ── #}
                <div class="tab-pane fade" id="pane-import" role="tabpanel">
                    <fieldset>
                        <legend><i class="fas fa-file-import me-1"></i>Import Style Definition</legend>
                        <p class="text-muted mb-3">
                            Upload an SLD, Symbology Encoding, or Mapbox Style JSON file to automatically populate the style editor.
                        </p>
                        <div class="mb-3">
                            <label for="import-file" class="form-label fw-bold">File</label>
                            <input type="file" class="form-control" id="import-file" accept=".sld,.xml,.json,.se">
                        </div>
                        <div id="import-warnings" class="d-none mb-3"></div>
                        <div id="import-success" class="d-none alert alert-success"><i class="fas fa-check-circle me-1"></i>Style imported successfully. Switch to the <strong>Visual Editor</strong> or <strong>Mapbox JSON</strong> tab to review.</div>
                    </fieldset>
                    <fieldset>
                        <legend><i class="fas fa-circle-info me-1"></i>Format Details</legend>

                        <h6 class="mt-2"><i class="fas fa-file-code me-1"></i>Mapbox Style JSON <span class="badge bg-success">Full support</span></h6>
                        <p class="text-muted ms-3 mb-3">
                            <code>.json</code> files are imported directly without conversion. The entire style object is loaded as-is into the editor.
                        </p>

                        <h6><i class="fas fa-file-code me-1"></i>SLD / Symbology Encoding <span class="badge bg-warning text-dark">Partial support</span></h6>
                        <p class="text-muted ms-3 mb-2">
                            <code>.sld</code>, <code>.xml</code>, and <code>.se</code> files are converted to Mapbox Style JSON. The conversion covers basic symbolizers:
                        </p>
                        <div class="row ms-2">
                            <div class="col-md-6">
                                <h6 class="text-success"><i class="fas fa-check me-1"></i>Converted</h6>
                                <ul class="import-info-list import-info-supported">
                                    <li><strong>PolygonSymbolizer</strong> — fill color/opacity, stroke color/width/opacity</li>
                                    <li><strong>LineSymbolizer</strong> — stroke color, width, opacity, dash arrays</li>
                                    <li><strong>PointSymbolizer</strong> — circle marks with fill and stroke</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-danger"><i class="fas fa-xmark me-1"></i>Not converted</h6>
                                <ul class="import-info-list import-info-unsupported">
                                    <li><strong>TextSymbolizer</strong> — labels, halos, placement</li>
                                    <li><strong>RasterSymbolizer</strong> — raster channel/color maps</li>
                                    <li><strong>External Graphics</strong> — icon image references</li>
                                    <li><strong>Multiple Rules / Filters</strong> — only first symbolizer per type</li>
                                    <li><strong>Vendor extensions</strong> — se:VendorOption etc.</li>
                                </ul>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>

        {% if readonly|default(false) %}</fieldset>{% endif %}
        <div class="mt-4 d-flex gap-2">
            {% if not readonly|default(false) %}
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save</button>
            {% endif %}
            <a href="{{ path('mapbender_manager_style_index') }}" class="btn btn-secondary">{{ readonly|default(false) ? 'Back' : 'Cancel' }}</a>
        </div>
    </form>
{% endblock %}

{% block js %}
    {{ parent() }}
    <script src="{{ asset('bundles/mapbendermanager/js/style-utils.js') }}"></script>
    <script src="{{ asset('bundles/mapbendermanager/js/sld-converter.js') }}"></script>
    <script src="{{ asset('bundles/mapbendermanager/js/style-editor.js') }}"></script>
{% endblock %}
