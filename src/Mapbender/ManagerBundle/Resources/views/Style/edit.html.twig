{% extends '@MapbenderManager/manager.html.twig' %}
{%- set title = (readonly|default(false)) ? 'mb.ogcapifeatures.admin.style.editor.title_view' | trans({'%id%': style.id}) : (style.id ? 'mb.ogcapifeatures.admin.style.editor.title_edit' | trans({'%id%': style.id}) : 'mb.ogcapifeatures.admin.style.editor.title_new' | trans) -%}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/mapbendermanager/css/style-editor.css') }}">
{% endblock %}

{% block manager_content %}
    <form method="post" novalidate action="{{ style.id ? path('mapbender_manager_style_edit', {id: style.id}) : path('mapbender_manager_style_new') }}"{{ readonly|default(false) ? ' class="style-readonly"' : '' }}>
        <input type="hidden" id="sourceType" name="sourceType" value="{{ style.sourceType|default('manual') }}">
        {% if readonly|default(false) %}
        <fieldset disabled>
        {% endif %}
        <div class="mb-4">
            <label for="name" class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.name_label' | trans }} <span class="text-danger">*</span></label>
            <input type="text" class="form-control{{ nameError|default(false) ? ' is-invalid' : '' }}" id="name" name="name" value="{{ style.name }}" required placeholder="{{ 'mb.ogcapifeatures.admin.style.editor.name_placeholder' | trans }}">
            {% if nameError|default(false) %}
                <div class="invalid-feedback">{{ 'mb.ogcapifeatures.admin.style.name_required' | trans }}</div>
            {% endif %}
        </div>
        {% if readonly|default(false) %}
        </fieldset>
        {% endif %}
        <div class="style-editor-tabs">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" id="tab-visual" data-bs-toggle="tab" data-bs-target="#pane-visual" role="tab">
                        <i class="fas fa-palette tab-icon"></i>{{ 'mb.ogcapifeatures.admin.style.editor.tab_visual' | trans }}
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" id="tab-json" data-bs-toggle="tab" data-bs-target="#pane-json" role="tab">
                        <i class="fas fa-code tab-icon"></i>{{ 'mb.ogcapifeatures.admin.style.editor.tab_json' | trans }}
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" id="tab-import" data-bs-toggle="tab" data-bs-target="#pane-import" role="tab">
                        <i class="fas fa-file-import tab-icon"></i>{{ 'mb.ogcapifeatures.admin.style.editor.tab_import' | trans }}
                        <span id="import-tab-warning" class="d-none badge bg-danger ms-1" title="{{ 'mb.ogcapifeatures.admin.style.editor.import_overwrite_badge' | trans }}">!</span>
                    </a>
                </li>
            </ul>
            <div class="tab-content">
                {# ── Visual Editor Tab ── #}
                <div class="tab-pane fade show active" id="pane-visual" role="tabpanel">

                    {# ── Mapbox Layer Editor (shown for Mapbox documents) ── #}
                    <div id="layers-editor" class="d-none">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-bold text-uppercase" style="font-size:12px;letter-spacing:0.5px;">
                                <i class="fas fa-layer-group me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.mapbox_layers' | trans }}
                            </span>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btn-add-layer">
                                <i class="fas fa-plus me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.add_layer' | trans }}
                            </button>
                        </div>
                        <div id="layer-accordion" class="accordion"></div>
                    </div>

                    {# ── Flat Editor (shown for simple style objects) ── #}
                    <div id="flat-editor">
                    <fieldset>
                        <legend><i class="fas fa-fill-drip me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.fill' | trans }}</legend>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.color' | trans }}</label>
                                    <div class="input-group -js-colorpicker">
                                        <input data-prop="fillColor" class="form-control" type="text" value="{{ _visual.fillColor ?? '#ff0000' }}">
                                        <span class="input-group-text input-group-addon"><i></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold w-100">{{ 'mb.ogcapifeatures.admin.style.editor.opacity' | trans }} <span class="float-end badge bg-secondary value-preview"></span></label>
                                    <input data-prop="fillOpacity" class="form-range" type="range" min="0" max="1" step="any" value="{{ _visual.fillOpacity ?? 1 }}">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.point_radius' | trans }}</label>
                                    <input data-prop="pointRadius" type="number" min="0" max="30" step="1" class="form-control" value="{{ _visual.pointRadius ?? 5 }}">
                                </div>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend><i class="fas fa-pen me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.stroke' | trans }}</legend>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.color' | trans }}</label>
                                    <div class="input-group -js-colorpicker">
                                        <input data-prop="strokeColor" class="form-control" type="text" value="{{ _visual.strokeColor ?? '#ffffff' }}">
                                        <span class="input-group-text input-group-addon"><i></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold w-100">{{ 'mb.ogcapifeatures.admin.style.editor.opacity' | trans }} <span class="float-end badge bg-secondary value-preview"></span></label>
                                    <input data-prop="strokeOpacity" class="form-range" type="range" min="0" max="1" step="any" value="{{ _visual.strokeOpacity ?? 1 }}">
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.width' | trans }}</label>
                                    <input data-prop="strokeWidth" type="number" min="0" max="10" step="1" class="form-control" value="{{ _visual.strokeWidth ?? 1 }}">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.line_cap' | trans }}</label>
                                    <select data-prop="strokeLinecap" class="form-select">
                                        <option value="round"{{ _visual.strokeLinecap == 'round' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.cap_round' | trans }}</option>
                                        <option value="square"{{ _visual.strokeLinecap == 'square' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.cap_square' | trans }}</option>
                                        <option value="butt"{{ _visual.strokeLinecap == 'butt' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.cap_butt' | trans }}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.dash_style' | trans }}</label>
                                    <select data-prop="strokeDashstyle" class="form-select">
                                        <option value="solid"{{ _visual.strokeDashstyle == 'solid' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.dash_solid' | trans }}</option>
                                        <option value="dot"{{ _visual.strokeDashstyle == 'dot' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.dash_dot' | trans }}</option>
                                        <option value="dash"{{ _visual.strokeDashstyle == 'dash' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.dash_dash' | trans }}</option>
                                        <option value="longdash"{{ _visual.strokeDashstyle == 'longdash' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.dash_long' | trans }}</option>
                                        <option value="dashdot"{{ _visual.strokeDashstyle == 'dashdot' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.dash_dashdot' | trans }}</option>
                                        <option value="longdashdot"{{ _visual.strokeDashstyle == 'longdashdot' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.dash_longdashdot' | trans }}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend><i class="fas fa-font me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.label_legend' | trans }}</legend>
                        <div class="mb-3">
                            <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.text' | trans }}</label>
                            <input data-prop="label" type="text" class="form-control" value="{{ _visual.label ?? '' }}" placeholder="e.g. ${name}">
                        </div>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.font_family' | trans }}</label>
                                    <select data-prop="fontFamily" class="form-select">
                                        {% set families = {
                                            'Arial, Helvetica, sans-serif': 'Arial',
                                            'Arial Black, Gadget, sans-serif': 'Arial Black',
                                            'Comic Sans MS, cursive, sans-serif': 'Comic Sans',
                                            'Georgia, serif': 'Georgia',
                                            'Impact, Charcoal, sans-serif': 'Impact',
                                            'Lucida Sans Unicode, Lucida Grande, sans-serif': 'Lucida',
                                            'Palatino Linotype, Book Antiqua, Palatino, serif': 'Palatino',
                                            'Tahoma, Geneva, sans-serif': 'Tahoma',
                                            'Times New Roman, Times, serif': 'Times New Roman',
                                            'Trebuchet MS, Helvetica, sans-serif': 'Trebuchet',
                                            'Verdana, Geneva, sans-serif': 'Verdana'
                                        } %}
                                        {% for val, lbl in families %}
                                            <option value="{{ val }}"{{ _visual.fontFamily == val ? ' selected' : '' }}>{{ lbl }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.font_size' | trans }}</label>
                                    <input data-prop="fontSize" type="number" min="5" max="30" class="form-control" value="{{ _visual.fontSize ?? 11 }}">
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.font_weight' | trans }}</label>
                                    <select data-prop="fontWeight" class="form-select">
                                        <option value="regular"{{ _visual.fontWeight == 'regular' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.weight_regular' | trans }}</option>
                                        <option value="bold"{{ _visual.fontWeight == 'bold' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.weight_bold' | trans }}</option>
                                        <option value="italic"{{ _visual.fontWeight == 'italic' ? ' selected' : '' }}>{{ 'mb.ogcapifeatures.admin.style.editor.weight_italic' | trans }}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.font_color' | trans }}</label>
                                    <div class="input-group -js-colorpicker">
                                        <input data-prop="fontColor" class="form-control" type="text" value="{{ _visual.fontColor ?? '#000000' }}">
                                        <span class="input-group-text input-group-addon"><i></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold w-100">{{ 'mb.ogcapifeatures.admin.style.editor.font_opacity' | trans }} <span class="float-end badge bg-secondary value-preview"></span></label>
                                    <input data-prop="fontOpacity" class="form-range" type="range" min="0" max="1" step="any" value="{{ _visual.fontOpacity ?? 1 }}">
                                </div>
                            </div>
                        </div>
                    </fieldset>

                    {# ── Preview (flat editor only) ── #}
                    <fieldset>
                        <legend><i class="fas fa-eye me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.preview_legend' | trans }}</legend>
                        <div class="row text-center">
                            <div class="col-sm-4">
                                <label class="form-label fw-bold d-block">{{ 'mb.ogcapifeatures.admin.style.editor.geom_point' | trans }}</label>
                                <canvas id="preview-point" data-geom="point" width="160" height="120" style="border:1px solid #dee2e6; border-radius:4px; background:#f8f9fa;"></canvas>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-bold d-block">{{ 'mb.ogcapifeatures.admin.style.editor.geom_line' | trans }}</label>
                                <canvas id="preview-line" data-geom="line" width="160" height="120" style="border:1px solid #dee2e6; border-radius:4px; background:#f8f9fa;"></canvas>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-bold d-block">{{ 'mb.ogcapifeatures.admin.style.editor.geom_polygon' | trans }}</label>
                                <canvas id="preview-polygon" data-geom="polygon" width="160" height="120" style="border:1px solid #dee2e6; border-radius:4px; background:#f8f9fa;"></canvas>
                            </div>
                        </div>
                    </fieldset>
                    </div>{# /flat-editor #}
                </div>

                {# ── Mapbox JSON Tab ── #}
                <div class="tab-pane fade" id="pane-json" role="tabpanel">
                    <div class="mb-3">
                        <label for="style" class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.mapbox_style_json' | trans }}</label>
                        <textarea class="form-control" id="style" name="style" rows="24"
                                  data-collection-id="{{ style.collectionId|default('') }}"
                                  data-is-new="{{ isNew|default(false) ? '1' : '0' }}">{{ style.style }}</textarea>
                        <div class="form-text text-muted mt-1"><i class="fas fa-circle-info me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.json_syntax_only_note' | trans }}</div>
                    </div>
                </div>

                {# ── Import Tab ── #}
                <div class="tab-pane fade" id="pane-import" role="tabpanel">
                    <div id="import-overwrite-warning" class="alert alert-warning d-none mb-3">
                        <i class="fas fa-triangle-exclamation me-1"></i>
                        <strong>{{ 'mb.ogcapifeatures.admin.style.editor.import_caution' | trans }}:</strong> {{ 'mb.ogcapifeatures.admin.style.editor.import_overwrite_text' | trans | raw }}
                    </div>
                    <fieldset>
                        <legend><i class="fas fa-file-import me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.import_legend' | trans }}</legend>
                        <p class="text-muted mb-3">
                            {{ 'mb.ogcapifeatures.admin.style.editor.import_desc' | trans }}
                        </p>
                        <div class="mb-3">
                            <label for="import-file" class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.import_file' | trans }}</label>
                            <input type="file" class="form-control" id="import-file" accept=".sld,.xml,.json,.se">
                        </div>
                        <div id="import-warnings" class="d-none mb-3"></div>
                        <div id="import-success" class="d-none alert alert-success"><i class="fas fa-check-circle me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.import_success' | trans | raw }}</div>
                    </fieldset>
                    <fieldset>
                        <legend><i class="fas fa-circle-info me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.format_details' | trans }}</legend>

                        <h6 class="mt-2"><i class="fas fa-file-code me-1"></i>Mapbox Style JSON <span class="badge bg-success">{{ 'mb.ogcapifeatures.admin.style.editor.format_full_support' | trans }}</span></h6>
                        <p class="text-muted ms-3 mb-3">
                            {{ 'mb.ogcapifeatures.admin.style.editor.format_mapbox_desc' | trans }}
                        </p>

                        <h6><i class="fas fa-file-code me-1"></i>SLD / Symbology Encoding <span class="badge bg-warning text-dark">{{ 'mb.ogcapifeatures.admin.style.editor.format_partial_support' | trans }}</span></h6>
                        <p class="text-muted ms-3 mb-2">
                            {{ 'mb.ogcapifeatures.admin.style.editor.format_sld_desc' | trans }}
                        </p>
                        <div class="row ms-2">
                            <div class="col-md-6">
                                <h6 class="text-success"><i class="fas fa-check me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.format_converted' | trans }}</h6>
                                <ul class="import-info-list import-info-supported">
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_polygon' | trans }}</li>
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_line' | trans }}</li>
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_point' | trans }}</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-danger"><i class="fas fa-xmark me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.format_not_converted' | trans }}</h6>
                                <ul class="import-info-list import-info-unsupported">
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_text' | trans }}</li>
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_raster' | trans }}</li>
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_external' | trans }}</li>
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_rules' | trans }}</li>
                                    <li>{{ 'mb.ogcapifeatures.admin.style.editor.format_sld_vendor' | trans }}</li>
                                </ul>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            {% if not readonly|default(false) %}
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.save' | trans }}</button>
            {% endif %}
            <a href="{{ path('mapbender_manager_style_index') }}" class="btn btn-secondary">{{ readonly|default(false) ? 'mb.ogcapifeatures.admin.style.editor.back' | trans : 'mb.ogcapifeatures.admin.style.editor.cancel' | trans }}</a>
        </div>
    </form>

    {# ── JS Templates (cloned by style-editor-layers.js / style-editor.js) ── #}
    <template id="tpl-layer-item">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse">
                    <canvas class="layer-mini-preview me-2" width="36" height="24"></canvas>
                    <i class="me-2"></i>
                    <span class="badge me-2 -js-type-badge"></span>
                    <span class="layer-id-label"></span>
                    <span class="badge bg-light text-dark ms-2 layer-rule-badge d-none"></span>
                    <span class="layer-filter-desc ms-2 d-none" title="">
                        <i class="fas fa-filter me-1"></i><span class="-js-filter-text"></span>
                    </span>
                </button>
            </h2>
            <div class="accordion-collapse collapse">
                <div class="accordion-body">
                    <div class="layer-full-preview mb-3">
                        <canvas class="layer-full-canvas" width="200" height="80"></canvas>
                    </div>
                    <div class="layer-paint-controls"></div>
                    <div class="text-end mt-2">
                        <button type="button" class="btn btn-sm btn-outline-danger -fn-remove-layer">
                            <i class="fas fa-trash-can me-1"></i>{{ 'mb.ogcapifeatures.admin.style.editor.remove_layer' | trans }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="tpl-color-row">
        <div class="row mb-2">
            <div class="col-sm-6">
                <label class="form-label fw-bold"></label>
                <div class="input-group input-group-sm -js-colorpicker">
                    <input class="form-control form-control-sm" type="text">
                    <span class="input-group-text input-group-addon"><i></i></span>
                </div>
            </div>
        </div>
    </template>

    <template id="tpl-range-row">
        <div class="row mb-2">
            <div class="col-sm-6">
                <label class="form-label fw-bold w-100">
                    <span class="-js-label-text"></span>
                    <span class="float-end badge bg-secondary layer-range-preview"></span>
                </label>
                <input class="form-range" type="range">
            </div>
        </div>
    </template>

    <template id="tpl-number-row">
        <div class="row mb-2">
            <div class="col-sm-4">
                <label class="form-label fw-bold"></label>
                <input type="number" class="form-control form-control-sm">
            </div>
        </div>
    </template>

    <template id="tpl-symbol-controls">
        <div class="row mb-2">
            <div class="col-sm-6">
                <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.text_field' | trans }}</label>
                <input data-layer-prop="text-field" type="text" class="form-control form-control-sm">
            </div>
            <div class="col-sm-3">
                <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.size' | trans }}</label>
                <input data-layer-prop="text-size" type="number" min="1" max="60" step="1" class="form-control form-control-sm">
            </div>
            <div class="col-sm-3">
                <label class="form-label fw-bold">{{ 'mb.ogcapifeatures.admin.style.editor.font' | trans }}</label>
                <input data-layer-prop="text-font" type="text" class="form-control form-control-sm">
            </div>
        </div>
    </template>

    <template id="tpl-no-props">
        <p class="text-muted small">{{ 'mb.ogcapifeatures.admin.style.editor.no_editable_properties' | trans }}</p>
    </template>

    <template id="tpl-warning-alert">
        <div class="alert alert-warning mb-1">
            <i class="fas fa-triangle-exclamation me-1"></i><span class="-js-warning-text"></span>
        </div>
    </template>
{% endblock %}

{% block js %}
    {{ parent() }}
    <script src="{{ asset('bundles/mapbendermanager/js/style-utils.js') }}"></script>
    <script src="{{ asset('bundles/mapbendermanager/js/sld-converter.js') }}"></script>
    <script src="{{ asset('bundles/mapbendermanager/js/style-editor-preview.js') }}"></script>
    <script src="{{ asset('bundles/mapbendermanager/js/style-editor-layers.js') }}"></script>
    <script src="{{ asset('bundles/mapbendermanager/js/style-editor.js') }}"></script>
    {% if readonly|default(false) %}
    <script>
    $(function() {
        document.querySelectorAll('.style-readonly input, .style-readonly textarea, .style-readonly select').forEach(function(el) {
            el.disabled = true;
        });
    });
    </script>
    {% endif %}
{% endblock %}
