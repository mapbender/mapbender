{% extends '@MapbenderManager/manager.html.twig' %}
{%- set title = 'mb.manager.admin.style.manager.title' | trans -%}

{% block manager_content %}
    {% if is_granted(constant('FOM\\UserBundle\\Security\\Permission\\ResourceDomainInstallation::ACTION_CREATE_STYLES')) %}
    <div class="list-head">
        <div class="row">
            <div class="col-sm-5 col-xs-12 col-12">
                <div class="content-box content-box-md">
                    <a href="{{ path('mapbender_manager_style_new') }}" title="{{ 'mb.manager.admin.style.manager.new_style' | trans }}">
                        <i class="fas fa-lg fa-plus"></i>
                        <span>{{ 'mb.manager.admin.style.manager.new_style' | trans }}</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="content-box content-box-lg">
    <table id="style-list" class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th style="width:50px">{{ 'mb.manager.admin.style.manager.th_id' | trans }}</th>
                <th style="width:120px">{{ 'mb.manager.admin.style.manager.th_preview' | trans }}</th>
                <th>{{ 'mb.manager.admin.style.manager.th_name' | trans }}</th>
                <th style="width:100px">{{ 'mb.manager.admin.style.manager.th_origin' | trans }}</th>
                <th style="width:80px">{{ 'mb.manager.admin.style.manager.th_source' | trans }}</th>
                <th style="width:130px">{{ 'mb.manager.admin.style.manager.th_actions' | trans }}</th>
            </tr>
            <tr class="table-light">
                <td></td>
                <td></td>
                <td><input id="filter-name" type="text" class="form-control form-control-sm" placeholder="{{ 'mb.manager.admin.style.manager.filter_name' | trans }}" title="{{ 'mb.ogcapifeatures.admin.filter.name_tooltip' | trans }}"></td>
                <td>
                    <select id="filter-origin" class="form-select form-select-sm" title="{{ 'mb.ogcapifeatures.admin.filter.origin_tooltip' | trans }}">
                        <option value="">{{ 'mb.manager.admin.style.manager.filter_all' | trans }}</option>
                        <option value="mapbox-json">{{ 'mb.ogcapifeatures.admin.filter.origin_mapbox_json' | trans }}</option>
                        <option value="manual">{{ 'mb.ogcapifeatures.admin.filter.origin_manual' | trans }}</option>
                        <option value="ogc_api">{{ 'mb.ogcapifeatures.admin.filter.origin_ogc_api' | trans }}</option>
                        <option value="digitizer">{{ 'mb.ogcapifeatures.admin.filter.origin_digitizer' | trans }}</option>
                        <option value="yaml">YAML</option>
                    </select>
                </td>
                <td><input id="filter-source" type="text" class="form-control form-control-sm" placeholder="{{ 'mb.manager.admin.style.manager.filter_source' | trans }}" title="{{ 'mb.ogcapifeatures.admin.filter.source_tooltip' | trans }}"></td>
                <td></td>
            </tr>
        </thead>
        <tbody>
            {% for style in styles %}
                <tr data-name="{{ style.name|default('')|lower }}"
                    data-origin="{{ style.yamlDefined ? 'yaml' : (style.sourceType|default('')) }}"
                    data-source="{{ style.sourceId|default('') }}">
                    <td>{{ style.id ?? style.yamlKey }}</td>
                    <td>
                        {% if style.multiLayer %}
                            <span class="text-muted small">{{ 'mb.manager.admin.style.multi_layer_preview' | trans({'%count%': style.layerCount}) }}</span>
                        {% else %}
                        <div class="d-flex gap-1">
                            <canvas class="style-preview" data-geom="point" data-style="{{ style.style|e('html_attr') }}" width="32" height="32" style="border:1px solid #dee2e6;border-radius:3px;background:#f8f9fa;"></canvas>
                            <canvas class="style-preview" data-geom="line" data-style="{{ style.style|e('html_attr') }}" width="32" height="32" style="border:1px solid #dee2e6;border-radius:3px;background:#f8f9fa;"></canvas>
                            <canvas class="style-preview" data-geom="polygon" data-style="{{ style.style|e('html_attr') }}" width="32" height="32" style="border:1px solid #dee2e6;border-radius:3px;background:#f8f9fa;"></canvas>
                        </div>
                        {% endif %}
                    </td>
                    <td>{{ style.name ?? ('mb.manager.admin.style.manager.fallback_name' | trans({id: style.id})) }}</td>
                    <td>
                        {% if style.yamlDefined %}
                            <span class="badge bg-warning text-dark">YAML</span>
                        {% elseif style.sourceType == 'mapbox-json' %}
                            <span class="badge bg-primary">{{ 'mb.ogcapifeatures.admin.filter.origin_mapbox_json' | trans }}</span>
                        {% elseif style.sourceType == 'manual' %}
                            <span class="badge bg-secondary">{{ 'mb.ogcapifeatures.admin.filter.origin_manual' | trans }}</span>
                        {% elseif style.sourceType == 'ogc_api' %}
                            <span class="badge bg-success">{{ 'mb.ogcapifeatures.admin.filter.origin_ogc_api' | trans }}</span>
                        {% elseif style.sourceType == 'digitizer' %}
                            <span class="badge bg-dark">{{ 'mb.ogcapifeatures.admin.filter.origin_digitizer' | trans }}</span>
                        {% elseif style.sourceType %}
                            <span class="badge bg-info">{{ style.sourceType }}</span>
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>{{ style.sourceId ?? '-' }}</td>
                    <td>
                        <div class="d-flex flex-nowrap gap-1">
                            {% if style.yamlDefined %}
                                <a class="btn btn-light btn-sm" href="{{ path('mapbender_manager_style_yaml_view', {key: style.yamlKey}) }}" title="{{ 'mb.manager.admin.style.manager.action_view' | trans }}"><i class="fas fa-eye"></i></a>
                                {% if is_granted(constant('FOM\\UserBundle\\Security\\Permission\\ResourceDomainInstallation::ACTION_CREATE_STYLES')) %}
                                <form method="post" action="{{ path('mapbender_manager_style_yaml_copy', {key: style.yamlKey}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('style_copy') }}">
                                    <button type="submit" class="btn btn-light btn-sm" title="{{ 'mb.manager.admin.style.manager.action_copy' | trans }}"><i class="far fa-copy"></i></button>
                                </form>
                                {% endif %}
                            {% else %}
                            {% if style.sourceType in ['manual', 'mapbox-json'] and is_granted(constant('FOM\\UserBundle\\Security\\Permission\\ResourceDomainInstallation::ACTION_EDIT_STYLES')) %}
                                <a class="btn btn-light btn-sm" href="{{ path('mapbender_manager_style_edit', {id: style.id}) }}" title="{{ 'mb.manager.admin.style.manager.action_edit' | trans }}"><i class="fas fa-pencil"></i></a>
                            {% else %}
                                <a class="btn btn-light btn-sm" href="{{ path('mapbender_manager_style_view', {id: style.id}) }}" title="{{ 'mb.manager.admin.style.manager.action_view' | trans }}"><i class="fas fa-eye"></i></a>
                            {% endif %}
                            {% if is_granted(constant('FOM\\UserBundle\\Security\\Permission\\ResourceDomainInstallation::ACTION_CREATE_STYLES')) %}
                            <form method="post" action="{{ path('mapbender_manager_style_copy', {id: style.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('style_copy') }}">
                                <button type="submit" class="btn btn-light btn-sm" title="{{ 'mb.manager.admin.style.manager.action_copy' | trans }}"><i class="far fa-copy"></i></button>
                            </form>
                            {% endif %}
                            {% if is_granted(constant('FOM\\UserBundle\\Security\\Permission\\ResourceDomainInstallation::ACTION_DELETE_STYLES')) and (style.sourceType != 'ogc_api' or not style.sourceId) %}
                            <form method="post" action="{{ path('mapbender_manager_style_delete', {id: style.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'mb.manager.admin.style.manager.confirm_delete' | trans | e('js') }}');">
                                <input type="hidden" name="_token" value="{{ csrf_token('style_delete') }}">
                                <button type="submit" class="btn btn-light btn-sm" title="{{ 'mb.manager.admin.style.manager.action_delete' | trans }}"><i class="far fa-trash-can"></i></button>
                            </form>
                            {% endif %}
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-muted">{{ 'mb.manager.admin.style.manager.no_styles' | trans }}</td></tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
{% endblock %}

{% block js %}
    {{ parent() }}
    <script src="{{ asset('bundles/mapbendermanager/js/style-utils.js') }}"></script>
    <script>
    $(function() {
        const rows = document.querySelectorAll('#style-list tbody tr[data-name]');
        const fName = document.getElementById('filter-name');
        const fOrigin = document.getElementById('filter-origin');
        const fSource = document.getElementById('filter-source');

        function matchesOrigin(rowOrigin, filter) {
            if (!filter) return true;
            return rowOrigin === filter;
        }

        function applyFilters() {
            const name = fName.value.toLowerCase();
            const origin = fOrigin.value;
            const source = fSource.value.toLowerCase();
            rows.forEach(row => {
                const match = (!name || row.dataset.name.includes(name))
                    && matchesOrigin(row.dataset.origin, origin)
                    && (!source || row.dataset.source.toLowerCase().includes(source));
                row.style.display = match ? '' : 'none';
            });
        }

        fName.addEventListener('input', applyFilters);
        fOrigin.addEventListener('change', applyFilters);
        fSource.addEventListener('input', applyFilters);
    });
    </script>
{% endblock %}
