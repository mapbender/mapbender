{% extends '@MapbenderManager/manager.html.twig' %}
{%- set title = 'Styles' -%}

{% block manager_content %}
    <div class="list-head">
        <div class="row">
            <div class="col-sm-5 col-xs-12 col-12">
                <a class="btn btn-outline-primary content-box content-box-md" href="{{ path('mapbender_manager_style_new') }}">
                    <i class="fas fa-plus fa-lg"></i>
                    <span>New Style</span>
                </a>
            </div>
        </div>
    </div>

    <table id="style-list" class="table table-striped table-hover mt-3 align-middle">
        <thead>
            <tr>
                <th style="width:50px">ID</th>
                <th style="width:120px">Preview</th>
                <th>Name</th>
                <th style="width:100px">Origin</th>
                <th style="width:80px">Source</th>
                <th style="width:130px">Actions</th>
            </tr>
            <tr class="table-light">
                <td></td>
                <td></td>
                <td><input id="filter-name" type="text" class="form-control form-control-sm" placeholder="Filter name…"></td>
                <td>
                    <select id="filter-origin" class="form-select form-select-sm">
                        <option value="">All</option>
                        <option value="mapbox-json">Mapbox JSON</option>
                        <option value="sld">SLD</option>
                        <option value="manual">Manual</option>
                        <option value="ogc_api">OGC API</option>
                        <option value="digitizer">Digitizer</option>
                    </select>
                </td>
                <td><input id="filter-source" type="text" class="form-control form-control-sm" placeholder="Source ID…"></td>
                <td></td>
            </tr>
        </thead>
        <tbody>
            {% for style in styles %}
                <tr data-name="{{ style.name|default('')|lower }}"
                    data-origin="{{ style.sourceType|default('') }}"
                    data-source="{{ style.sourceId|default('') }}">
                    <td>{{ style.id }}</td>
                    <td>
                        <div class="d-flex gap-1">
                            <canvas class="style-preview" data-geom="point" data-style="{{ style.style|e('html_attr') }}" width="32" height="32" style="border:1px solid #dee2e6;border-radius:3px;background:#f8f9fa;"></canvas>
                            <canvas class="style-preview" data-geom="line" data-style="{{ style.style|e('html_attr') }}" width="32" height="32" style="border:1px solid #dee2e6;border-radius:3px;background:#f8f9fa;"></canvas>
                            <canvas class="style-preview" data-geom="polygon" data-style="{{ style.style|e('html_attr') }}" width="32" height="32" style="border:1px solid #dee2e6;border-radius:3px;background:#f8f9fa;"></canvas>
                        </div>
                    </td>
                    <td>{{ style.name ?? ('Style #' ~ style.id) }}</td>
                    <td>
                        {% if style.sourceType == 'mapbox-json' %}
                            <span class="badge bg-primary">Mapbox JSON</span>
                        {% elseif style.sourceType == 'sld' %}
                            <span class="badge bg-warning text-dark">SLD</span>
                        {% elseif style.sourceType == 'manual' %}
                            <span class="badge bg-secondary">Manual</span>
                        {% elseif style.sourceType == 'ogc_api' %}
                            <span class="badge bg-success">OGC API</span>
                        {% elseif style.sourceType == 'digitizer' %}
                            <span class="badge bg-dark">Digitizer</span>
                        {% elseif style.sourceType %}
                            <span class="badge bg-info">{{ style.sourceType }}</span>
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>{{ style.sourceId ?? '-' }}</td>
                    <td>
                        <div class="d-flex flex-nowrap gap-1">
                            {% if style.sourceType in ['manual', 'mapbox-json', 'sld'] %}
                                <a class="btn btn-light btn-sm" href="{{ path('mapbender_manager_style_edit', {id: style.id}) }}" title="Edit"><i class="fas fa-pen"></i></a>
                            {% else %}
                                <a class="btn btn-light btn-sm" href="{{ path('mapbender_manager_style_view', {id: style.id}) }}" title="View"><i class="fas fa-eye"></i></a>
                            {% endif %}
                            <form method="post" action="{{ path('mapbender_manager_style_copy', {id: style.id}) }}" class="d-inline">
                                <button type="submit" class="btn btn-light btn-sm" title="Copy"><i class="fas fa-copy"></i></button>
                            </form>
                            <form method="post" action="{{ path('mapbender_manager_style_delete', {id: style.id}) }}" class="d-inline" onsubmit="return confirm('Delete this style?');">
                                <button type="submit" class="btn btn-light btn-sm" title="Delete"><i class="far fa-trash-can"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-muted">No styles configured yet.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}

{% block js %}
    {{ parent() }}
    <script src="{{ asset('bundles/mapbendermanager/js/style-utils.js') }}"></script>
    <script>
    $(function() {
        const rows = document.querySelectorAll('#style-list tbody tr[data-name]');
        const fName = document.getElementById('filter-name');
        const fOrigin = document.getElementById('filter-origin');
        const fSource = document.getElementById('filter-source');

        function matchesOrigin(rowOrigin, filter) {
            if (!filter) return true;
            return rowOrigin === filter;
        }

        function applyFilters() {
            const name = fName.value.toLowerCase();
            const origin = fOrigin.value;
            const source = fSource.value.toLowerCase();
            rows.forEach(row => {
                const match = (!name || row.dataset.name.includes(name))
                    && matchesOrigin(row.dataset.origin, origin)
                    && (!source || row.dataset.source.toLowerCase().includes(source));
                row.style.display = match ? '' : 'none';
            });
        }

        fName.addEventListener('input', applyFilters);
        fOrigin.addEventListener('change', applyFilters);
        fSource.addEventListener('input', applyFilters);
    });
    </script>
{% endblock %}
